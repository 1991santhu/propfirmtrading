# Tradovate credentials
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CLIENT_ID=your_numeric_client_id
TRADOVATE_SECRET=your_secret
TRADOVATE_DEVICE_ID=your_device_id

# Use 'demo' for testing, 'live' for real money
TRADOVATE_ENV=demo

# Your Tradovate account details (found in account dashboard)
TRADOVATE_ACCOUNT_ID=your_numeric_account_id
TRADOVATE_ACCOUNT_SPEC=your_username@your_firm

# Bot config
WEBHOOK_SECRET=choose_a_long_random_string
SYMBOL=MNQM5
CONTRACTS=3
STOP_POINTS=60
MAX_DAILY_LOSSES=2
MAX_DAILY_TRADES=5
CLOSE_HOUR_EST=16
CLOSE_MINUTE_EST=40

# Exit strategy: "fixed_2r" (breakeven at 1R, close all at 2R) or "trailing" (partial exits, trail remainder)
EXIT_STRATEGY=fixed_2r

# Databento — best free option for 2+ years of /MNQ historical data (backtest only)
# Sign up free at databento.com → get $10 credit → covers ~2 years of MNQ 5-min
# Key at: databento.com/portal/settings/api-keys
# Run: python -m backtest.download --source databento --date-from 2023-01-01 --date-to 2024-12-31
DATABENTO_API_KEY=

# Polygon.io — for downloading 2+ years of /MNQ historical data (backtest only)
# Free tier at polygon.io gives access to delayed data. Sign up at polygon.io/dashboard
# Then run: python -m backtest.download --source polygon --date-from 2024-01-01 --date-to 2025-12-31
POLYGON_API_KEY=

# Reddit API — optional, gives richer data with comments (register free app at reddit.com/prefs/apps)
# Without these, the scraper falls back to Reddit's public JSON API automatically.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PropResearchBot/1.0
